<section class="kanban-section">
  <div class="kanban-toolbar">
    <button class="add-column-btn" id="add-column-btn" type="button">
      Add New Column
      <i class="fa-solid fa-circle-plus"></i>
    </button>
  </div>

  <div class="board-root" id="board-root"></div>
</section>

<style is:global>
  .kanban-section {
    background-color: #37435c;
    max-width: 1600px;
    margin: 0 auto;
    padding: 1rem;
    border-radius: 12px;
  }

  .kanban-toolbar {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
  }

  .kanban-toolbar button {
    font-size: large;
    cursor: pointer;
  }

  .kanban-toolbar i {
    font-size: 20px;
    margin-left: 0.25rem;
  }

  .board-root {
    width: 100%;
    min-height: 100vh;
    padding: 1.5rem;
    border-radius: 12px;
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 1.5rem;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 1rem;
    scrollbar-width: none;
  }

  .board-root::-webkit-scrollbar {
    display: none;
  }

  .add-task-btn,
  .add-column-btn {
    background: none;
    border: none;
    color: white;
    transition: color 0.3s ease-in-out;
  }

  .add-task-btn:hover,
  .add-column-btn:hover {
    color: rgb(0, 0, 0);
  }

  .kanban-column {
    background-color: #4162a4;
    border-radius: 12px;
    padding: 1rem;
    min-width: 320px;
    max-width: 320px;
    flex-shrink: 0;
    min-height: 200px;
    color: white;
    box-shadow: 0 4px 6px rgb(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .column-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .column-header h3 {
    font-weight: 700;
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 180px;
    color: black;
  }

  .column-actions {
    display: flex;
    gap: 0.5rem;
  }

  .column-actions button {
    background: transparent;
    border: none;
    padding: 0;
    box-shadow: none;
    outline: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  .column-actions button i {
    background: transparent;
    display: block;
    line-height: 1;
  }

  .column-body {
    background-color: #eef2f5;
    border-radius: 10px;
    min-height: 80vh;
    padding: 0.75rem;
  }

  @media (max-width: 900px) {
    .board-root {
      flex-direction: column;
      overflow-x: hidden;
      overflow-y: auto;
    }

    .kanban-column {
      width: 100%;
      min-width: 100%;
      max-width: 100%;
      flex-shrink: 1;
    }
  }
</style>

