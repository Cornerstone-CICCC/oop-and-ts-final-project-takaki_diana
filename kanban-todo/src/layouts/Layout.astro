  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    font-family: system-ui, -apple-system, "Roboto", sans-serif;
    background-color: #0b121c;
    color: white;
  }

  main {
    padding: 2rem;
  }

  [hidden] {
    display: none !important;
  }
